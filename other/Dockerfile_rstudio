# Start with the CAI R 4.5 PBJ runtime (R is ALREADY installed in this base,
# so we do NOT reinstall R - we only add RStudio Server + sparklyr).
FROM docker.repository.cloudera.com/cloudera/cdsw/ml-runtime-pbj-workbench-r4.5-standard:2026.01.1-b6

USER root

# curl for the download.
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# -----------------------------
# Install RStudio Server
# -----------------------------
# NO "latest" build exists on download2. Pass a real version at build time:
#   docker build --build-arg RSTUDIO_VERSION=<current> ...
# Find the current filename at https://posit.co/download/rstudio-server/
# (the part between "rstudio-server-" and "-amd64.deb"). The default below is a
# placeholder and is NOT guaranteed to exist - override it.
ARG RSTUDIO_VERSION=2026.04.0-526

# set -e => the step fails if download/install fails (no more silent success).
# curl -f => fail on HTTP error instead of saving an error page.
# apt install ./file.deb => installs the .deb AND its dependencies.
# test -x => hard guard: build stops HERE if the binary is missing.
RUN set -eux; \
    curl -fL "https://download2.rstudio.org/server/jammy/amd64/rstudio-server-${RSTUDIO_VERSION}-amd64.deb" \
        -o /tmp/rstudio-server.deb; \
    apt-get update; \
    apt-get install -y --no-install-recommends /tmp/rstudio-server.deb; \
    rm -f /tmp/rstudio-server.deb; \
    rm -rf /var/lib/apt/lists/*; \
    test -x /usr/sbin/rstudio-server

# -----------------------------
# Install sparklyr (no Spark bundled)
# -----------------------------
# install.packages() exits 0 even when a package fails to build, which would let
# the image ship without sparklyr and only fail at session time. Guard it so the
# build hard-fails if sparklyr is not importable afterwards.
RUN R -e "install.packages('sparklyr', repos='https://cloud.r-project.org', dependencies=TRUE); if (!requireNamespace('sparklyr', quietly=TRUE)) quit(status=1)"

# -----------------------------
# Security remediation for base-image CVEs
# -----------------------------
# The vulnerability scan flags OS/Python packages inherited from the base image.
# We cannot edit the base image, so we patch the affected packages to their
# fixed versions in this derived layer. Run this AFTER installing RStudio so its
# dependencies are patched too.
#   postgresql-16 -> CVE-2026-6475 / CVE-2026-6477 (fixed 16.14-0ubuntu0.24.04.1)
#   mysql-8.0     -> CVE-2026-46862 / CVE-2026-46863 (fixed 8.0.46-0ubuntu0.24.04.3)
# apt upgrade pulls the current Ubuntu 24.04 security updates for all packages.
RUN apt-get update \
 && apt-get upgrade -y \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

# Replace git-lfs with the official upstream release, which is built on a patched
# Go toolchain. The base image ships git-lfs compiled with a vulnerable Go stdlib
# (CVE-2025-68121, crypto/tls). apt cannot fix this because the Go version is
# baked into the compiled binary, so we overwrite the binary itself.
# Confirm the new binary reports go>=1.24.13 (via `go version /usr/bin/git-lfs`
# on a host with Go) and bump GIT_LFS_VERSION if a newer release is needed.
ARG GIT_LFS_VERSION=3.7.1
RUN set -eux; \
    curl -fL "https://github.com/git-lfs/git-lfs/releases/download/v${GIT_LFS_VERSION}/git-lfs-linux-amd64-v${GIT_LFS_VERSION}.tar.gz" \
        -o /tmp/git-lfs.tgz; \
    tar -xzf /tmp/git-lfs.tgz -C /tmp; \
    install -m0755 "$(find /tmp -name git-lfs -type f | head -n1)" /usr/bin/git-lfs; \
    rm -rf /tmp/git-lfs*; \
    git-lfs version

# Patch the Python cryptography package (GHSA-537c-gmf6-5ccf, fixed in >=48.0.1).
RUN pip3 install --no-cache-dir --upgrade 'cryptography>=48.0.1'

# Replace the esbuild binary bundled inside Quarto (inside RStudio Server). The
# RStudio .deb ships esbuild compiled with a vulnerable Go stdlib (CVE-2025-68121,
# crypto/tls; go1.23.12 < 1.24.13). esbuild is a self-contained Go binary, so we
# overwrite it with the current release (built on a patched Go toolchain) without
# rebuilding RStudio. The trailing grep prints the new toolchain for build logs.
ARG ESBUILD_VERSION=0.28.1
RUN set -eux; \
    curl -fL "https://registry.npmjs.org/@esbuild/linux-x64/-/linux-x64-${ESBUILD_VERSION}.tgz" \
        -o /tmp/esbuild.tgz; \
    tar -xzf /tmp/esbuild.tgz -C /tmp; \
    find /usr/lib/rstudio-server -type f -path '*/quarto/bin/tools/*/esbuild' \
        -exec install -m0755 /tmp/package/bin/esbuild {} \; ; \
    rm -rf /tmp/esbuild.tgz /tmp/package; \
    grep -aom1 -E 'go1\.[0-9]+(\.[0-9]+)?' \
        "$(find /usr/lib/rstudio-server -type f -path '*/quarto/bin/tools/*/esbuild' | head -n1)"

# -----------------------------
# Configure RStudio for CML
# -----------------------------
RUN chown -R cdsw:cdsw /var/lib/rstudio-server && chmod -R 777 /var/lib/rstudio-server
# cdsw must read /etc/rstudio/database.conf and write pid/log files under /var/run.
RUN mkdir -p /var/run/rstudio-server /var/log/rstudio/rstudio-server \
 && usermod -aG rstudio-server cdsw 2>/dev/null || true \
 && chown -R cdsw:cdsw /var/run/rstudio-server /var/log/rstudio /etc/rstudio \
 && chmod -R 777 /var/run/rstudio-server /var/log/rstudio \
 && chmod 644 /etc/rstudio/database.conf
COPY rserver.conf /etc/rstudio/rserver.conf
COPY rstudio-cml  /usr/local/bin/rstudio-cml
# Strip CR chars in case files were edited on Windows (CRLF => bad interpreter).
RUN sed -i 's/\r$//' /usr/local/bin/rstudio-cml /etc/rstudio/rserver.conf \
 && chmod +x /usr/local/bin/rstudio-cml

# CML launches whatever ml-runtime-editor points to.
RUN ln -sf /usr/local/bin/rstudio-cml /usr/local/bin/ml-runtime-editor

# (Removed the original `RUN export PATH=.../4.1` line: a RUN-scoped export does
#  nothing at runtime and 4.1 did not match this image.)

# -----------------------------
# Permissions (CML requirements)
# -----------------------------
RUN for i in /etc /var /etc/alternatives /var/lib/dpkg/ /home /runtime-addons; do \
      if [ -d ${i} ]; then chmod 777 ${i}; fi; \
    done

RUN chown cdsw /

# Spark/Hadoop runtime add-ons symlink into /usr/lib/* at session start. Those
# paths must not already exist, and cdsw must be able to create symlinks there.
RUN rm -rf /usr/lib/hadoop /usr/lib/spark 2>/dev/null || true

RUN chmod u+w /usr/lib /usr/bin

RUN for i in /bin /var /etc /opt /var/lib/dpkg/ /sbin /usr /home /runtime-addons; do \
      if [ -d ${i} ]; then \
        chown cdsw ${i}; \
        find ${i} -type d -exec chown cdsw {} +; \
      fi; \
    done

# -----------------------------
# Runtime Metadata
# -----------------------------
ENV ML_RUNTIME_EDITOR="RStudio" \
    ML_RUNTIME_EDITION="RStudio 2026 Community Runtime" \
    ML_RUNTIME_SHORT_VERSION="2026.03" \
    ML_RUNTIME_MAINTENANCE_VERSION="4" \
    ML_RUNTIME_FULL_VERSION="2026.03.4" \
    ML_RUNTIME_DESCRIPTION="RStudio Server with sparklyr on PBJ Workbench R4.5 runtime (CVE remediation)" \
    ML_RUNTIME_KERNEL="R 4.5"

LABEL com.cloudera.ml.runtime.editor=$ML_RUNTIME_EDITOR \
      com.cloudera.ml.runtime.edition=$ML_RUNTIME_EDITION \
      com.cloudera.ml.runtime.full-version=$ML_RUNTIME_FULL_VERSION \
      com.cloudera.ml.runtime.short-version=$ML_RUNTIME_SHORT_VERSION \
      com.cloudera.ml.runtime.maintenance-version=$ML_RUNTIME_MAINTENANCE_VERSION \
      com.cloudera.ml.runtime.description=$ML_RUNTIME_DESCRIPTION \
      com.cloudera.ml.runtime.kernel=$ML_RUNTIME_KERNEL

USER cdsw
